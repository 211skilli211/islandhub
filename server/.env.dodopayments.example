# Environment Variables for DodoPayments

# Add these to your .env file in the server directory

# DodoPayments API Configuration
DODO_API_KEY=your_public_api_key_here
DODO_SECRET_KEY=your_secret_key_here
DODO_WEBHOOK_SECRET=your_webhook_secret_here
DODO_MODE=sandbox
DODO_API_URL=https://sandbox.dodopayments.com/v1

# Frontend URL for payment redirects
FRONTEND_URL=http://localhost:3000

# Instructions:
# 1. Get your API keys from DodoPayments dashboard
# 2. Copy these values to server/.env
# 3. Replace placeholder values with actual keys
# 4. Set DODO_MODE=live when ready for production
# 5. Update DODO_API_URL to production URL when going live
