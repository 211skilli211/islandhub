# Server Backend Environment Variables
# Copy this file to .env.production and fill in the values

# Node environment
NODE_ENV=production
PORT=5001

# Database Configuration (PostgreSQL - Neon/Supabase/DigitalOcean)
DB_HOST=your-db-host.neon.tech
DB_PORT=5432
DB_NAME=your_database_name
DB_USER=your_db_user
DB_PASSWORD=your_secure_password

# Redis Configuration (Redis Cloud/DigitalOcean)
REDIS_HOST=your-redis-host.rediscloud.com
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# JWT Configuration
JWT_SECRET=your_super_secure_jwt_secret_min_32_chars

# CORS Configuration
ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# Optional: Email configuration (if using nodemailer)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_email_password

# Optional: Payment gateways
STRIPE_SECRET_KEY=sk_test_your_stripe_secret
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
