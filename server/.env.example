# IslandFund API Server - Environment Configuration Template
# Copy this file to .env.local for local development
# For production, copy to .env.production and fill in production values

# ==============================================================================
# ENVIRONMENT: LOCAL DEVELOPMENT vs PRODUCTION
# ==============================================================================
# Copy to .env.local for local dev
# Copy to .env.production for Railway deployment

# ==============================================================================
# Server Configuration
# ==============================================================================
PORT=5001
NODE_ENV=development

# JWT Secret - MUST be different for production!
# Generate with: openssl rand -base64 64
JWT_SECRET=your_super_secret_key_here

# CORS Origins - comma-separated list
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5001

# ==============================================================================
# Database Configuration (PostgreSQL)
# ==============================================================================
# LOCAL DEVELOPMENT:
DB_USER=postgres
DB_HOST=localhost
DB_NAME=islandfund
DB_PASSWORD=your_db_password
DB_PORT=5433

# DOCKER/LOCAL CONTAINER:
# DB_HOST=postgres
# DB_PORT=5432

# PRODUCTION (Neon PostgreSQL):
# Get connection string from: https://console.neon.tech/clusters
# Format: postgres://user:password@host:5432/database?sslmode=require
# DB_HOST=your-db-host.neon.tech
# DB_PORT=5432
# DB_NAME=your_database_name
# DB_USER=your_db_user
# DB_PASSWORD=your_secure_password
# DATABASE_URL=postgres://user:password@host:5432/database?sslmode=require

# ==============================================================================
# Redis Configuration
# ==============================================================================
# LOCAL DEVELOPMENT:
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# PRODUCTION (Redis Cloud / Railway Redis):
# Get credentials from: https://app.redislabs.com/
# REDIS_HOST=your-redis-host.rediscloud.com
# REDIS_PORT=6379
# REDIS_PASSWORD=your_redis_password
# REDIS_URL=redis://:password@host:6379

# ==============================================================================
# Payment Gateway Configuration
# ==============================================================================

# Stripe (Primary Payment Processor)
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# PayPal
# Get from: https://developer.paypal.com/developer/applications
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox  # Change to 'live' for production

# WiPay (Caribbean Payment Gateway)
WIPAY_API_URL=https://api.wipay.co/v1/payment
WIPAY_API_KEY=your_wipay_api_key
WIPAY_API_SECRET=your_wipay_api_secret
WIPAY_CALLBACK_SECRET=your_wipay_callback_secret

# Kyrrex Crypto Gateway
KYRREX_API_URL=https://api-onofframp.kyrrex.mt
KYRREX_API_KEY=your_kyrrex_api_key
KYRREX_WEBHOOK_SECRET=your_kyrrex_webhook_secret

# DodoPayments (Subscription Management)
# Get from: https://dashboard.dodopayments.com/
DODO_SECRET_KEY=your_dodo_secret_key
DODO_WEBHOOK_SECRET=your_dodo_webhook_secret
DODO_MODE=sandbox  # Change to 'live' for production
DODO_API_URL=https://api.dodopayments.com/v1

# ==============================================================================
# Application URLs
# ==============================================================================
# Base URL for API server (used for callbacks and webhooks)
BASE_URL=http://localhost:5001

# Frontend URL for redirects
FRONTEND_URL=http://localhost:3000

# PRODUCTION:
# BASE_URL=https://api.yourdomain.com
# FRONTEND_URL=https://yourdomain.com

# ==============================================================================
# Email Configuration (Optional - nodemailer)
# ==============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
FROM_EMAIL=noreply@yourdomain.com

# For production, consider using:
# - SendGrid: https://app.sendgrid.com/
# - Mailgun: https://app.mailgun.com/
# - Resend: https://resend.com/

# ==============================================================================
# Security & Rate Limiting
# ==============================================================================
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# ==============================================================================
# Monitoring & Logging
# ==============================================================================
LOG_LEVEL=debug  # Options: error, warn, info, debug
METRICS_ENABLED=true
METRICS_PORT=9464

# ==============================================================================
# File Upload Configuration
# ==============================================================================
# MAX_FILE_SIZE=10485760  # 10MB in bytes

# ==============================================================================
# Session Configuration
# ==============================================================================
SESSION_SECRET=your_session_secret_here

# ==============================================================================
# PRODUCTION CHECKLIST (Railway)
# ==============================================================================
# 1. Set NODE_ENV=production
# 2. Update DB_* to Neon PostgreSQL connection values
# 3. Update REDIS_* to Redis Cloud connection values
# 4. Set JWT_SECRET to a strong random value (min 32 chars)
# 5. Update ALLOWED_ORIGINS with your production domains
# 6. Set STRIPE_SECRET_KEY to live Stripe key
# 7. Set PAYPAL_MODE=live with live credentials
# 8. Update BASE_URL to your Railway API URL
# 9. Update FRONTEND_URL to your Vercel deployment URL
# 10. Set LOG_LEVEL=info for production

# ==============================================================================
# RAILYAY DEPLOYMENT NOTES
# ==============================================================================
# 1. Add these environment variables in Railway Project Settings
# 2. Enable "Autodeploy" from your GitHub repository
# 3. Set "Start Command" to: npm start
# 4. Set "Root Directory" to: server
# 5. Add PostgreSQL and Redis services from Railway marketplace
# 6. Connect PostgreSQL and Redis to your service
# 7. Set environment variable "DATABASE_URL" from PostgreSQL service
# 8. Set environment variable "REDIS_URL" from Redis service
