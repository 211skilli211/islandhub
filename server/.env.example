# IslandFund API Server - Environment Configuration

# ================================================
# Server Configuration
# ================================================
PORT=5001
JWT_SECRET=your_super_secret_key_here
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5001

# ================================================
# Database Configuration (PostgreSQL)
# ================================================
# For local development:
DB_USER=postgres
DB_HOST=localhost
DB_NAME=islandfund
DB_PASSWORD=your_db_password_here
DB_PORT=5433

# For Docker:
# DB_HOST=postgres
# DB_PORT=5432

# ================================================
# Redis Configuration (Caching)
# ================================================
REDIS_HOST=localhost
REDIS_PORT=6379

# ================================================
# Payment Gateway Configuration
# ================================================

# Stripe (Primary Payment Processor)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# PayPal
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox  # Change to 'live' for production

# WiPay (Caribbean Payment Gateway)
WIPAY_API_URL=https://api.wipay.co/v1/payment
WIPAY_API_KEY=your_wipay_api_key
WIPAY_API_SECRET=your_wipay_api_secret
WIPAY_CALLBACK_SECRET=your_wipay_callback_secret

# Kyrrex Crypto Gateway
KYRREX_API_URL=https://api-onofframp.kyrrex.mt
KYRREX_API_KEY=your_kyrrex_api_key
KYRREX_WEBHOOK_SECRET=your_kyrrex_webhook_secret

# DodoPayments (Subscription Management)
DODO_SECRET_KEY=your_dodo_secret_key
DODO_WEBHOOK_SECRET=your_dodo_webhook_secret
DODO_MODE=sandbox  # Change to 'live' for production
DODO_API_URL=https://api.dodopayments.com/v1

# ================================================
# Application URLs
# ================================================
BASE_URL=http://localhost:5001
FRONTEND_URL=http://localhost:3000

# ================================================
# Email Configuration (Optional)
# ================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
FROM_EMAIL=noreply@islandfund.com

# ================================================
# Security & Rate Limiting
# ================================================
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# ================================================
# Monitoring & Logging
# ================================================
LOG_LEVEL=debug  # Options: error, warn, info, debug
METRICS_ENABLED=true
METRICS_PORT=9464
