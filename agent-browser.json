                            "value": "{{driver.email}}"
                        },
                        {
                            "action": "type",
                            "selector": "input[type='password']",
                            "value": "{{driver.password}}"
                        },
                        {
                            "action": "click",
                            "selector": "button[type='submit']"
                        },
                        {
                            "action": "wait",
                            "timeout": 3000
                        },
                        {
                            "action": "snapshot"
                        },
                        {
                            "action": "saveSession",
                            "name": "driver-session"
                        }
                    ]
